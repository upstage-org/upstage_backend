# Copy to state.env and fill in before running phases (or let phase 20 prompt).
# state.env is gitignored.

APP_DOMAIN=app.example.org
SVC_DOMAIN=svc.example.org
STREAMING_DOMAIN=streaming.example.org
CERTBOT_EMAIL=you@example.org

# prod | dev — which run_docker_compose_* scripts to use under service_containers/ and app_containers/
UPSTAGE_COMPOSE_PROFILE=prod
